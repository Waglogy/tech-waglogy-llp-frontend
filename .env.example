# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# Insights / blog: api (default) uses CMS when reachable; falls back to built-in 50 articles if the API fails.
# Set to "static" to use only the built-in catalog (no API).
# VITE_PUBLIC_INSIGHTS_SOURCE=static
# Merge CMS posts with the built-in catalog (fetches up to 500 from API, adds static slugs not in CMS):
# VITE_MERGE_STATIC_INSIGHTS=true

# Environment
VITE_ENV=development
